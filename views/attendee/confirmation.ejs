<%- include('../partials/header') %>

<div class="max-w-lg mx-auto text-center py-10">
    <div class="text-7xl mb-4">🎉</div>
    <h1 class="text-4xl font-extrabold text-slate-800 mb-2">Booking Confirmed!</h1>
    <p class="text-slate-400 mb-8">Your tickets have been booked successfully.</p>

    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-8 text-left mb-6">
        <h2 class="text-xl font-bold text-slate-800 mb-1"><%= booking.event_title %></h2>
        <p class="text-slate-400 text-sm mb-6">📅 <%= new Date(booking.event_date).toLocaleString('en-GB', {weekday:'long',day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></p>

        <div class="flex flex-col divide-y divide-slate-100">
            <div class="flex justify-between py-3 text-sm">
                <span class="text-slate-400">Attendee</span>
                <strong class="text-slate-800"><%= booking.attendee_name %></strong>
            </div>
            <% if (booking.full_price_tickets > 0) { %>
            <div class="flex justify-between py-3 text-sm">
                <span class="text-slate-400">Full-Price Tickets</span>
                <strong class="text-slate-800"><%= booking.full_price_tickets %> × £<%= parseFloat(booking.full_price_cost).toFixed(2) %></strong>
            </div>
            <% } %>
            <% if (booking.concession_tickets > 0) { %>
            <div class="flex justify-between py-3 text-sm">
                <span class="text-slate-400">Concession Tickets</span>
                <strong class="text-slate-800"><%= booking.concession_tickets %> × £<%= parseFloat(booking.concession_cost).toFixed(2) %></strong>
            </div>
            <% } %>
            <div class="flex justify-between py-3">
                <span class="text-slate-500 font-semibold">Total</span>
                <strong class="text-indigo-600 text-xl">£<%= total.toFixed(2) %></strong>
            </div>
            <div class="flex justify-between py-3 text-sm">
                <span class="text-slate-400">Booking Reference</span>
                <strong class="text-slate-800 font-mono">#<%= String(booking.id).padStart(6,'0') %></strong>
            </div>
            <div class="flex justify-between py-3 text-sm">
                <span class="text-slate-400">Booked At</span>
                <strong class="text-slate-800"><%= new Date(booking.booked_at).toLocaleString('en-GB') %></strong>
            </div>
        </div>
    </div>

    <div class="flex gap-3 justify-center flex-wrap">
        <a href="/attendee" class="bg-indigo-600 text-white font-semibold text-sm px-6 py-2.5 rounded-xl hover:bg-indigo-700 transition">← Browse More Events</a>
        <a href="/attendee/events/<%= booking.event_id %>" class="border border-slate-300 text-slate-600 font-semibold text-sm px-6 py-2.5 rounded-xl hover:bg-slate-100 transition">View Event</a>
    </div>
</div>

<%- include('../partials/footer') %>
