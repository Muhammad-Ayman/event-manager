<%- include('../partials/header') %>

<div class="confirmation-page">
    <div class="confirmation-icon">🎉</div>
    <h1>Booking Confirmed!</h1>
    <p class="confirmation-subtitle">Your tickets have been booked successfully.</p>

    <div class="confirmation-card">
        <h2><%= booking.event_title %></h2>
        <p class="conf-date">📅 <%= formatDate(booking.event_date, 'EEEE, d MMMM yyyy, HH:mm') %></p>

        <div class="conf-details">
            <div class="conf-row">
                <span>Attendee</span>
                <strong><%= booking.attendee_name %></strong>
            </div>
            <% if (booking.full_price_tickets > 0) { %>
            <div class="conf-row">
                <span>Full-Price Tickets</span>
                <strong><%= booking.full_price_tickets %> × £<%= parseFloat(booking.full_price_cost).toFixed(2) %></strong>
            </div>
            <% } %>
            <% if (booking.concession_tickets > 0) { %>
            <div class="conf-row">
                <span>Concession Tickets</span>
                <strong><%= booking.concession_tickets %> × £<%= parseFloat(booking.concession_cost).toFixed(2) %></strong>
            </div>
            <% } %>
            <div class="conf-row conf-row--total">
                <span>Total</span>
                <strong>£<%= total.toFixed(2) %></strong>
            </div>
            <div class="conf-row">
                <span>Booking Reference</span>
                <strong>#<%= booking.id.toString().padStart(6, '0') %></strong>
            </div>
            <div class="conf-row">
                <span>Booked At</span>
                <strong><%= formatDate(booking.booked_at, 'dd/MM/yyyy, HH:mm') %></strong>
            </div>
        </div>
    </div>

    <div class="confirmation-actions">
        <a href="/attendee" class="btn btn-primary">← Browse More Events</a>
        <a href="/attendee/events/<%= booking.event_id %>" class="btn btn-outline">View Event</a>
    </div>
</div>

<%- include('../partials/footer') %>
