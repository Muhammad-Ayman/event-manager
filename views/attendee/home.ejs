<%- include('../partials/header') %>

<!-- Attendee hero banner -->
<div class="bg-gradient-to-r from-indigo-600 to-sky-500 text-white rounded-2xl p-10 mb-8">
    <p class="text-sm opacity-75 mb-1 uppercase tracking-widest font-semibold">Attendee Home Page</p>
    <h1 class="text-4xl font-extrabold mb-2"><%= settings.name %></h1>
    <p class="text-lg opacity-90"><%= settings.description %></p>
</div>

<!-- Events list -->
<section>
    <h2 class="text-xl font-bold text-slate-700 mb-4">📅 Upcoming Events</h2>

    <% if (events.length === 0) { %>
        <div class="border-2 border-dashed border-slate-200 rounded-xl p-10 text-center text-slate-400">
            No events are currently available. Check back soon!
        </div>
    <% } else { %>
        <div class="flex flex-col gap-4">
        <% events.forEach(function(event) {
            const d = new Date(event.event_date);
        %>
            <a href="/attendee/events/<%= event.id %>"
               class="group flex items-center gap-5 bg-white border border-slate-200 rounded-xl px-6 py-5 shadow-sm hover:shadow-md hover:border-indigo-400 transition text-slate-800 no-underline">

                <!-- Date badge -->
                <div class="bg-indigo-50 border-2 border-indigo-300 rounded-xl min-w-[64px] text-center py-2 px-1 flex flex-col">
                    <span class="text-2xl font-extrabold text-indigo-600 leading-none"><%= d.getDate() %></span>
                    <span class="text-xs font-bold text-indigo-500 uppercase"><%= d.toLocaleString('en-GB', {month:'short'}) %></span>
                    <span class="text-xs text-slate-400"><%= d.getFullYear() %></span>
                </div>

                <!-- Event info -->
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold text-slate-800 text-lg mb-1 group-hover:text-indigo-600 transition"><%= event.title %></h3>
                    <p class="text-slate-400 text-sm truncate"><%= event.description.length > 100 ? event.description.slice(0,100) + '…' : event.description %></p>
                    <div class="flex gap-4 mt-2 text-xs text-slate-400">
                        <span>🎟 From £<%= Math.min(event.full_price_cost, event.concession_cost).toFixed(2) %></span>
                        <span>⏰ <%= d.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'}) %></span>
                    </div>
                </div>

                <span class="text-indigo-400 font-bold text-xl group-hover:translate-x-1 transition">→</span>
            </a>
        <% }); %>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
