<%- include('../partials/header') %>

<div class="bg-gradient-to-r from-indigo-600 to-sky-500 text-white rounded-2xl p-10 mb-8">
    <h1 class="text-lg opacity-80 font-normal mb-3">Attendee Home Page</h1>
    <div>
        <h2 class="text-4xl font-extrabold"><%= settings.name %></h2>
        <p class="mt-1 text-base opacity-85"><%= settings.description %></p>
    </div>
</div>

<section class="mb-10">
    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">📅 Upcoming Events</h2>

    <% if (events.length === 0) { %>
        <div class="bg-white border-2 border-dashed border-slate-200 rounded-lg p-8 text-center text-slate-500">
            <p>No events are currently available. Check back soon!</p>
        </div>
    <% } else { %>
        <div class="flex flex-col gap-4">
            <% events.forEach(event => { %>
                <% const d = dateFnsParseISO(event.event_date); %>
                <a href="/attendee/events/<%= event.id %>" class="flex items-center gap-5 bg-white border border-slate-200 rounded-lg p-5 no-underline text-slate-800 shadow-sm hover:-translate-y-0.5 hover:border-indigo-600 hover:shadow-md transition-all duration-200">
                    <div class="bg-indigo-50 border-2 border-indigo-600 rounded-lg min-w-[68px] text-center py-2 px-1 flex flex-col">
                        <span class="text-3xl font-extrabold text-indigo-600 leading-none"><%= dateFnsFormat(d, 'd') %></span>
                        <span class="text-xs font-bold uppercase text-indigo-600"><%= dateFnsFormat(d, 'MMM') %></span>
                        <span class="text-xs text-slate-500"><%= dateFnsFormat(d, 'yyyy') %></span>
                    </div>
                    <div class="flex-1">
                        <h3 class="text-lg font-bold mb-1"><%= event.title %></h3>
                        <p class="text-sm text-slate-500 mb-2"><%= event.description.length > 100 ? event.description.slice(0,100) + '…' : event.description %></p>
                        <div class="flex gap-4 text-sm text-slate-500">
                            <span>🎟 From £<%= Math.min(event.full_price_cost, event.concession_cost).toFixed(2) %></span>
                            <span>⏰ <%= dateFnsFormat(d, 'HH:mm') %></span>
                        </div>
                    </div>
                    <div class="text-xl text-indigo-600 font-bold">→</div>
                </a>
            <% }); %>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
