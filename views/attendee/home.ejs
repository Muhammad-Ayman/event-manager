<%- include('../partials/header') %>

<div class="attendee-hero">
    <h1>Attendee Home Page</h1>
    <div class="site-info">
        <h2><%= settings.name %></h2>
        <p><%= settings.description %></p>
    </div>
</div>

<section class="section">
    <h2 class="section-title">📅 Upcoming Events</h2>

    <% if (events.length === 0) { %>
        <div class="empty-state">
            <p>No events are currently available. Check back soon!</p>
        </div>
    <% } else { %>
        <div class="event-grid">
            <% events.forEach(event => { %>
                <a href="/attendee/events/<%= event.id %>" class="event-card">
                    <div class="event-card-date">
                        <% const d = dateFnsParseISO(event.event_date); %>
                        <span class="event-card-day"><%= dateFnsFormat(d, 'd') %></span>
                        <span class="event-card-month"><%= dateFnsFormat(d, 'MMM') %></span>
                        <span class="event-card-year"><%= dateFnsFormat(d, 'yyyy') %></span>
                    </div>
                    <div class="event-card-body">
                        <h3 class="event-card-title"><%= event.title %></h3>
                        <p class="event-card-desc"><%= event.description.length > 100 ? event.description.slice(0,100) + '…' : event.description %></p>
                        <div class="event-card-meta">
                            <span>🎟 From £<%= Math.min(event.full_price_cost, event.concession_cost).toFixed(2) %></span>
                            <span>⏰ <%= dateFnsFormat(d, 'HH:mm') %></span>
                        </div>
                    </div>
                    <div class="event-card-arrow">→</div>
                </a>
            <% }); %>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
