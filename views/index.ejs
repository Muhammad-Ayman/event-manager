<%- include('partials/header') %>

<div class="text-center py-16">
    <div class="text-7xl mb-4">🎟</div>
    <h1 class="text-4xl font-extrabold text-slate-800 mb-3">Welcome to Event Manager</h1>
    <p class="text-slate-500 text-lg mb-10">Create and manage events, or browse and book your next experience.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">

        <a href="/organiser" class="group bg-white border border-slate-200 rounded-2xl p-8 text-left shadow hover:shadow-md hover:border-indigo-400 transition flex flex-col gap-3">
            <div class="text-4xl">🗂</div>
            <h2 class="text-xl font-bold text-slate-800">Organiser</h2>
            <p class="text-slate-500 text-sm flex-1">Create, edit, and publish events. Manage your site settings and view booking reports.</p>
            <span class="inline-block mt-2 bg-indigo-600 text-white text-sm font-semibold px-4 py-2 rounded-lg group-hover:bg-indigo-700 transition">Go to Organiser →</span>
        </a>

        <a href="/attendee" class="group bg-white border border-slate-200 rounded-2xl p-8 text-left shadow hover:shadow-md hover:border-sky-400 transition flex flex-col gap-3">
            <div class="text-4xl">🙋</div>
            <h2 class="text-xl font-bold text-slate-800">Attendee</h2>
            <p class="text-slate-500 text-sm flex-1">Browse upcoming events and book your tickets quickly and easily.</p>
            <span class="inline-block mt-2 bg-sky-500 text-white text-sm font-semibold px-4 py-2 rounded-lg group-hover:bg-sky-600 transition">Browse Events →</span>
        </a>

    </div>
</div>

<%- include('partials/footer') %>
