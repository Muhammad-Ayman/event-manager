<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <h1>Bookings – <%= event.title %></h1>
        <p class="page-subtitle text-muted">
            Event date: <strong><%= formatDate(event.event_date, 'dd/MM/yyyy, HH:mm') %></strong>
        </p>
    </div>
    <a href="/organiser" class="btn btn-outline">← Back to Organiser Home</a>
</div>

<!-- Summary cards -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-number"><%= bookings.length %></div>
        <div class="stat-label">Total Bookings</div>
    </div>
    <div class="stat-card">
        <div class="stat-number"><%= totalFull %></div>
        <div class="stat-label">Full-Price Tickets Sold</div>
    </div>
    <div class="stat-card">
        <div class="stat-number"><%= totalConcession %></div>
        <div class="stat-label">Concession Tickets Sold</div>
    </div>
    <div class="stat-card stat-card--revenue">
        <div class="stat-number">£<%= totalRevenue.toFixed(2) %></div>
        <div class="stat-label">Estimated Revenue</div>
    </div>
</div>

<!-- Capacity bars -->
<div class="capacity-section">
    <h3>Capacity</h3>
    <div class="capacity-row">
        <span class="capacity-label">Full-Price (<%= totalFull %> / <%= event.full_price_tickets %>)</span>
        <div class="progress-bar">
            <div class="progress-fill" style="width: <%= event.full_price_tickets > 0 ? Math.round((totalFull / event.full_price_tickets) * 100) : 0 %>%"></div>
        </div>
        <span class="capacity-pct"><%= event.full_price_tickets > 0 ? Math.round((totalFull / event.full_price_tickets) * 100) : 0 %>%</span>
    </div>
    <div class="capacity-row">
        <span class="capacity-label">Concession (<%= totalConcession %> / <%= event.concession_tickets %>)</span>
        <div class="progress-bar">
            <div class="progress-fill progress-fill--concession" style="width: <%= event.concession_tickets > 0 ? Math.round((totalConcession / event.concession_tickets) * 100) : 0 %>%"></div>
        </div>
        <span class="capacity-pct"><%= event.concession_tickets > 0 ? Math.round((totalConcession / event.concession_tickets) * 100) : 0 %>%</span>
    </div>
</div>

<!-- Bookings list -->
<section class="section">
    <h2 class="section-title">All Bookings</h2>

    <% if (bookings.length === 0) { %>
        <div class="empty-state">
            <p>No bookings yet for this event.</p>
        </div>
    <% } else { %>
        <div class="event-table-wrapper">
            <table class="event-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Attendee Name</th>
                        <th>Full-Price Tickets</th>
                        <th>Concession Tickets</th>
                        <th>Amount Paid</th>
                        <th>Booked At</th>
                    </tr>
                </thead>
                <tbody>
                <% bookings.forEach((b, i) => { %>
                    <tr>
                        <td class="text-muted"><%= i + 1 %></td>
                        <td><strong><%= b.attendee_name %></strong></td>
                        <td><%= b.full_price_tickets %></td>
                        <td><%= b.concession_tickets %></td>
                        <td>£<%= ((b.full_price_tickets * event.full_price_cost) + (b.concession_tickets * event.concession_cost)).toFixed(2) %></td>
                        <td class="date-small"><%= formatDate(b.booked_at, 'dd/MM/yyyy, HH:mm') %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
