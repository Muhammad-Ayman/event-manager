<%- include('../partials/header') %>

<div class="flex flex-wrap items-start justify-between gap-4 mb-8 pb-6 border-b border-slate-200">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-800">Bookings – <%= event.title %></h1>
        <p class="text-slate-400 text-sm mt-1">
            Event date: <strong><%= event.event_date ? new Date(event.event_date).toLocaleString('en-GB') : '—' %></strong>
        </p>
    </div>
    <a href="/organiser" class="inline-flex items-center border border-slate-300 text-slate-600 font-semibold text-sm px-4 py-2 rounded-lg hover:bg-slate-100 transition">← Back to Organiser Home</a>
</div>

<!-- Summary stat cards -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="bg-white border border-slate-200 rounded-xl p-5 text-center shadow-sm">
        <div class="text-3xl font-extrabold text-indigo-600"><%= bookings.length %></div>
        <div class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Total Bookings</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-5 text-center shadow-sm">
        <div class="text-3xl font-extrabold text-indigo-600"><%= totalFull %></div>
        <div class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Full-Price Sold</div>
    </div>
    <div class="bg-white border border-slate-200 rounded-xl p-5 text-center shadow-sm">
        <div class="text-3xl font-extrabold text-indigo-600"><%= totalConcession %></div>
        <div class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Concession Sold</div>
    </div>
    <div class="bg-green-50 border border-green-200 rounded-xl p-5 text-center shadow-sm">
        <div class="text-3xl font-extrabold text-green-600">£<%= totalRevenue.toFixed(2) %></div>
        <div class="text-xs text-slate-400 mt-1 uppercase tracking-wide">Est. Revenue</div>
    </div>
</div>

<!-- Capacity bars -->
<div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 mb-8">
    <h3 class="font-bold text-slate-700 mb-4">Capacity</h3>
    <div class="mb-3">
        <div class="flex justify-between text-sm text-slate-500 mb-1">
            <span>Full-Price (<%= totalFull %> / <%= event.full_price_tickets %>)</span>
            <span><%= event.full_price_tickets > 0 ? Math.round((totalFull / event.full_price_tickets) * 100) : 0 %>%</span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-3">
            <div class="bg-indigo-500 h-3 rounded-full transition-all" style="width: <%= event.full_price_tickets > 0 ? Math.round((totalFull / event.full_price_tickets) * 100) : 0 %>%"></div>
        </div>
    </div>
    <div>
        <div class="flex justify-between text-sm text-slate-500 mb-1">
            <span>Concession (<%= totalConcession %> / <%= event.concession_tickets %>)</span>
            <span><%= event.concession_tickets > 0 ? Math.round((totalConcession / event.concession_tickets) * 100) : 0 %>%</span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-3">
            <div class="bg-amber-400 h-3 rounded-full transition-all" style="width: <%= event.concession_tickets > 0 ? Math.round((totalConcession / event.concession_tickets) * 100) : 0 %>%"></div>
        </div>
    </div>
</div>

<!-- Bookings table -->
<section>
    <h2 class="text-xl font-bold text-slate-700 mb-4">All Bookings</h2>

    <% if (bookings.length === 0) { %>
        <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center text-slate-400">
            No bookings yet for this event.
        </div>
    <% } else { %>
        <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm bg-white">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 text-slate-500 uppercase text-xs tracking-wide">
                    <tr>
                        <th class="text-left px-4 py-3">#</th>
                        <th class="text-left px-4 py-3">Attendee Name</th>
                        <th class="text-left px-4 py-3">Full-Price Tickets</th>
                        <th class="text-left px-4 py-3">Concession Tickets</th>
                        <th class="text-left px-4 py-3">Amount Paid</th>
                        <th class="text-left px-4 py-3">Booked At</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                <% bookings.forEach(function(b, i) { %>
                    <tr class="hover:bg-slate-50 transition">
                        <td class="px-4 py-3 text-slate-400"><%= i + 1 %></td>
                        <td class="px-4 py-3 font-semibold text-slate-800"><%= b.attendee_name %></td>
                        <td class="px-4 py-3 text-slate-600"><%= b.full_price_tickets %></td>
                        <td class="px-4 py-3 text-slate-600"><%= b.concession_tickets %></td>
                        <td class="px-4 py-3 text-slate-700 font-medium">
                            £<%= ((b.full_price_tickets * event.full_price_cost) + (b.concession_tickets * event.concession_cost)).toFixed(2) %>
                        </td>
                        <td class="px-4 py-3 text-slate-400 text-xs whitespace-nowrap"><%= new Date(b.booked_at).toLocaleString('en-GB') %></td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
