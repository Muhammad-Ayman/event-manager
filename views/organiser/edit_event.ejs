<%- include('../partials/header') %>

<div class="page-header">
    <div>
        <h1>Organiser – Edit Event</h1>
        <p class="page-subtitle text-muted">
            Created: <strong><%= formatDate(event.created_at, 'dd/MM/yyyy, HH:mm') %></strong>
            &nbsp;|&nbsp;
            Last modified: <strong><%= formatDate(event.last_modified, 'dd/MM/yyyy, HH:mm') %></strong>
        </p>
    </div>
    <a href="/organiser" class="btn btn-outline">← Back to Organiser Home</a>
</div>

<div class="form-card">
    <% if (errors.length > 0) { %>
        <div class="alert alert-error">
            <ul>
                <% errors.forEach(err => { %>
                    <li><%= err %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <form action="/organiser/events/<%= event.id %>/edit" method="POST" novalidate>

        <div class="form-group">
            <label for="title">Event Title <span class="required">*</span></label>
            <input
                type="text"
                id="title"
                name="title"
                class="form-input"
                value="<%= event.title %>"
                placeholder="e.g. Morning Yoga Session"
                required
            />
        </div>

        <div class="form-group">
            <label for="description">Event Description</label>
            <textarea
                id="description"
                name="description"
                class="form-input"
                rows="5"
                placeholder="Describe the event for potential attendees…"
            ><%= event.description %></textarea>
        </div>

        <div class="form-group">
            <label for="event_date">Event Date & Time <span class="required">*</span></label>
            <input
                type="datetime-local"
                id="event_date"
                name="event_date"
                class="form-input"
                value="<%= event.event_date ? event.event_date.slice(0,16) : '' %>"
                required
            />
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="full_price_tickets">Full-Price Tickets Available <span class="required">*</span></label>
                <input
                    type="number"
                    id="full_price_tickets"
                    name="full_price_tickets"
                    class="form-input"
                    value="<%= event.full_price_tickets %>"
                    min="0"
                    required
                />
            </div>
            <div class="form-group">
                <label for="full_price_cost">Full-Price Ticket Price (£) <span class="required">*</span></label>
                <input
                    type="number"
                    id="full_price_cost"
                    name="full_price_cost"
                    class="form-input"
                    value="<%= parseFloat(event.full_price_cost).toFixed(2) %>"
                    min="0"
                    step="0.01"
                    required
                />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="concession_tickets">Concession Tickets Available <span class="required">*</span></label>
                <input
                    type="number"
                    id="concession_tickets"
                    name="concession_tickets"
                    class="form-input"
                    value="<%= event.concession_tickets %>"
                    min="0"
                    required
                />
            </div>
            <div class="form-group">
                <label for="concession_cost">Concession Ticket Price (£) <span class="required">*</span></label>
                <input
                    type="number"
                    id="concession_cost"
                    name="concession_cost"
                    class="form-input"
                    value="<%= parseFloat(event.concession_cost).toFixed(2) %>"
                    min="0"
                    step="0.01"
                    required
                />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">💾 Save Changes</button>
            <a href="/organiser" class="btn btn-outline">Discard</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
