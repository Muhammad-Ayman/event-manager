<%- include('../partials/header') %>

<div class="flex flex-wrap items-start justify-between gap-4 mb-8 pb-6 border-b border-slate-200">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-800">Organiser – Edit Event</h1>
        <p class="text-slate-400 text-sm mt-1">
            Created: <strong><%= new Date(event.created_at).toLocaleString('en-GB') %></strong>
            &nbsp;|&nbsp;
            Last modified: <strong><%= new Date(event.last_modified).toLocaleString('en-GB') %></strong>
        </p>
    </div>
    <a href="/organiser" class="inline-flex items-center border border-slate-300 text-slate-600 font-semibold text-sm px-4 py-2 rounded-lg hover:bg-slate-100 transition">← Back to Organiser Home</a>
</div>

<div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-8 max-w-2xl">

    <% if (errors.length > 0) { %>
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-xl p-4 mb-6">
            <ul class="list-disc list-inside space-y-1 text-sm">
                <% errors.forEach(function(err) { %><li><%= err %></li><% }); %>
            </ul>
        </div>
    <% } %>

    <form action="/organiser/events/<%= event.id %>/edit" method="POST">

        <div class="mb-5">
            <label for="title" class="block text-sm font-semibold text-slate-700 mb-1">Event Title <span class="text-red-500">*</span></label>
            <input type="text" id="title" name="title"
                   value="<%= event.title %>"
                   placeholder="e.g. Morning Yoga Session"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" />
        </div>

        <div class="mb-5">
            <label for="description" class="block text-sm font-semibold text-slate-700 mb-1">Event Description</label>
            <textarea id="description" name="description" rows="4"
                      placeholder="Describe the event for potential attendees…"
                      class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition resize-y"><%= event.description %></textarea>
        </div>

        <div class="mb-5">
            <label for="event_date" class="block text-sm font-semibold text-slate-700 mb-1">Event Date & Time <span class="text-red-500">*</span></label>
            <input type="datetime-local" id="event_date" name="event_date"
                   value="<%= event.event_date ? event.event_date.slice(0,16) : '' %>"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" />
        </div>

        <!-- Ticket fields in 2-column grid -->
        <div class="grid grid-cols-2 gap-4 mb-5">
            <div>
                <label for="full_price_tickets" class="block text-sm font-semibold text-slate-700 mb-1">Full-Price Tickets <span class="text-red-500">*</span></label>
                <input type="number" id="full_price_tickets" name="full_price_tickets"
                       value="<%= event.full_price_tickets %>" min="0"
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" />
            </div>
            <div>
                <label for="full_price_cost" class="block text-sm font-semibold text-slate-700 mb-1">Full-Price Cost (£) <span class="text-red-500">*</span></label>
                <input type="number" id="full_price_cost" name="full_price_cost"
                       value="<%= parseFloat(event.full_price_cost).toFixed(2) %>" min="0" step="0.01"
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" />
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-6">
            <div>
                <label for="concession_tickets" class="block text-sm font-semibold text-slate-700 mb-1">Concession Tickets <span class="text-red-500">*</span></label>
                <input type="number" id="concession_tickets" name="concession_tickets"
                       value="<%= event.concession_tickets %>" min="0"
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" />
            </div>
            <div>
                <label for="concession_cost" class="block text-sm font-semibold text-slate-700 mb-1">Concession Cost (£) <span class="text-red-500">*</span></label>
                <input type="number" id="concession_cost" name="concession_cost"
                       value="<%= parseFloat(event.concession_cost).toFixed(2) %>" min="0" step="0.01"
                       class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" />
            </div>
        </div>

        <div class="flex gap-3 pt-4 border-t border-slate-100">
            <button type="submit" class="bg-indigo-600 text-white font-semibold text-sm px-5 py-2 rounded-lg hover:bg-indigo-700 transition cursor-pointer">💾 Save Changes</button>
            <a href="/organiser" class="border border-slate-300 text-slate-600 font-semibold text-sm px-5 py-2 rounded-lg hover:bg-slate-100 transition">Discard</a>
        </div>

    </form>
</div>

<%- include('../partials/footer') %>
