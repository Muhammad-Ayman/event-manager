<%- include('../partials/header') %>

<div class="flex items-start justify-between flex-wrap gap-4 mb-8 pb-5 border-b-2 border-slate-200">
    <div>
        <h1 class="text-2xl font-bold">Organiser – Edit Event</h1>
        <p class="mt-1 text-sm text-slate-500">
            Created: <strong class="text-slate-800"><%= formatDate(event.created_at, 'dd/MM/yyyy, HH:mm') %></strong>
            &nbsp;|&nbsp;
            Last modified: <strong class="text-slate-800"><%= formatDate(event.last_modified, 'dd/MM/yyyy, HH:mm') %></strong>
        </p>
    </div>
    <a href="/organiser" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer no-underline whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-transparent text-indigo-600 border-2 border-indigo-600 hover:bg-indigo-50">← Back to Organiser Home</a>
</div>

<div class="bg-white border border-slate-200 rounded-lg p-8 max-w-[680px] shadow-sm mb-8">
    <% if (errors.length > 0) { %>
        <div class="bg-red-50 border border-red-300 text-red-900 rounded-lg px-5 py-3 mb-5 text-sm">
            <ul class="pl-5 list-disc">
                <% errors.forEach(err => { %>
                    <li class="mt-1"><%= err %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <form action="/organiser/events/<%= event.id %>/edit" method="POST" novalidate>

        <div class="mb-5">
            <label for="title" class="block text-sm font-semibold mb-1">Event Title <span class="text-red-500">*</span></label>
            <input
                type="text"
                id="title"
                name="title"
                class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all"
                value="<%= event.title %>"
                placeholder="e.g. Morning Yoga Session"
                required
            />
        </div>

        <div class="mb-5">
            <label for="description" class="block text-sm font-semibold mb-1">Event Description</label>
            <textarea
                id="description"
                name="description"
                class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all resize-y"
                rows="5"
                placeholder="Describe the event for potential attendees…"
            ><%= event.description %></textarea>
        </div>

        <div class="mb-5">
            <label for="event_date" class="block text-sm font-semibold mb-1">Event Date & Time <span class="text-red-500">*</span></label>
            <input
                type="datetime-local"
                id="event_date"
                name="event_date"
                class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all"
                value="<%= event.event_date ? event.event_date.slice(0,16) : '' %>"
                required
            />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="mb-5">
                <label for="full_price_tickets" class="block text-sm font-semibold mb-1">Full-Price Tickets Available <span class="text-red-500">*</span></label>
                <input
                    type="number"
                    id="full_price_tickets"
                    name="full_price_tickets"
                    class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all"
                    value="<%= event.full_price_tickets %>"
                    min="0"
                    required
                />
            </div>
            <div class="mb-5">
                <label for="full_price_cost" class="block text-sm font-semibold mb-1">Full-Price Ticket Price (£) <span class="text-red-500">*</span></label>
                <input
                    type="number"
                    id="full_price_cost"
                    name="full_price_cost"
                    class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all"
                    value="<%= parseFloat(event.full_price_cost).toFixed(2) %>"
                    min="0"
                    step="0.01"
                    required
                />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="mb-5">
                <label for="concession_tickets" class="block text-sm font-semibold mb-1">Concession Tickets Available <span class="text-red-500">*</span></label>
                <input
                    type="number"
                    id="concession_tickets"
                    name="concession_tickets"
                    class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all"
                    value="<%= event.concession_tickets %>"
                    min="0"
                    required
                />
            </div>
            <div class="mb-5">
                <label for="concession_cost" class="block text-sm font-semibold mb-1">Concession Ticket Price (£) <span class="text-red-500">*</span></label>
                <input
                    type="number"
                    id="concession_cost"
                    name="concession_cost"
                    class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all"
                    value="<%= parseFloat(event.concession_cost).toFixed(2) %>"
                    min="0"
                    step="0.01"
                    required
                />
            </div>
        </div>

        <div class="flex gap-3 pt-4 mt-2 border-t border-slate-200 flex-wrap">
            <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold border-none cursor-pointer whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md active:translate-y-0 bg-indigo-600 text-white hover:bg-indigo-800">💾 Save Changes</button>
            <a href="/organiser" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer no-underline whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-transparent text-indigo-600 border-2 border-indigo-600 hover:bg-indigo-50">Discard</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
