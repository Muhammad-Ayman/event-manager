<%- include('../partials/header') %>

<div class="flex items-start justify-between flex-wrap gap-4 mb-8 pb-5 border-b-2 border-slate-200">
    <div>
        <h1 class="text-2xl font-bold">Organiser Home Page</h1>
        <p class="mt-1 text-sm text-slate-500"><strong class="text-slate-800"><%= settings.name %></strong> – <%= settings.description %></p>
    </div>
    <div class="flex gap-3 flex-wrap items-center">
        <a href="/organiser/settings" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer no-underline whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-transparent text-indigo-600 border-2 border-indigo-600 hover:bg-indigo-50">⚙️ Site Settings</a>
        <form action="/organiser/events/new" method="POST" style="display:inline;">
            <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold border-none cursor-pointer whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md active:translate-y-0 bg-indigo-600 text-white hover:bg-indigo-800">+ Create New Event</button>
        </form>
    </div>
</div>

<section class="mb-10">
    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">📢 Published Events <span class="inline-block px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-800"><%= publishedEvents.length %></span></h2>

    <% if (publishedEvents.length === 0) { %>
        <div class="bg-white border-2 border-dashed border-slate-200 rounded-lg p-8 text-center text-slate-500">
            <p>No published events yet. Publish a draft to make it visible to attendees.</p>
        </div>
    <% } else { %>
        <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
            <table class="w-full border-collapse text-sm">
                <thead>
                    <tr class="bg-slate-100 text-left">
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Title</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Event Date</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Created</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Published</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Full Tickets</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Concession Tickets</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Sharing Link</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Actions</th>
                    </tr>
                </thead>
                <tbody>
                <% publishedEvents.forEach(event => { %>
                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-3 border-b border-slate-200"><strong><%= event.title %></strong></td>
                        <td class="px-4 py-3 border-b border-slate-200"><%= formatDate(event.event_date, 'd MMM yyyy') %></td>
                        <td class="px-4 py-3 border-b border-slate-200 text-xs text-slate-500 whitespace-nowrap"><%= formatDate(event.created_at, 'dd/MM/yyyy') %></td>
                        <td class="px-4 py-3 border-b border-slate-200 text-xs text-slate-500 whitespace-nowrap"><%= formatDate(event.published_at, 'dd/MM/yyyy') %></td>
                        <td class="px-4 py-3 border-b border-slate-200">
                            <span class="flex flex-col">
                                <%= event.booked_full %> / <%= event.full_price_tickets %> booked
                                <small class="text-xs text-slate-500">(£<%= parseFloat(event.full_price_cost).toFixed(2) %>)</small>
                            </span>
                        </td>
                        <td class="px-4 py-3 border-b border-slate-200">
                            <span class="flex flex-col">
                                <%= event.booked_concession %> / <%= event.concession_tickets %> booked
                                <small class="text-xs text-slate-500">(£<%= parseFloat(event.concession_cost).toFixed(2) %>)</small>
                            </span>
                        </td>
                        <td class="px-4 py-3 border-b border-slate-200">
                            <a href="/attendee/events/<%= event.id %>" class="text-xs text-indigo-600 whitespace-nowrap" target="_blank" title="Attendee link">
                                🔗 /attendee/events/<%= event.id %>
                            </a>
                        </td>
                        <td class="px-4 py-3 border-b border-slate-200">
                            <div class="flex gap-1.5 flex-wrap items-center">
                                <a href="/organiser/events/<%= event.id %>/bookings" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold cursor-pointer no-underline whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-transparent text-indigo-600 border-2 border-indigo-600 hover:bg-indigo-50">📋 Bookings</a>
                                <form action="/organiser/events/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Delete this event and all its bookings?');" style="display:inline;">
                                    <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold border-none cursor-pointer whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-red-500 text-white hover:bg-red-700">🗑 Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<section class="mb-10">
    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">📝 Draft Events <span class="inline-block px-2 py-0.5 rounded-full text-xs font-bold bg-orange-100 text-orange-800"><%= draftEvents.length %></span></h2>

    <% if (draftEvents.length === 0) { %>
        <div class="bg-white border-2 border-dashed border-slate-200 rounded-lg p-8 text-center text-slate-500">
            <p>No draft events. Click <strong>+ Create New Event</strong> to get started.</p>
        </div>
    <% } else { %>
        <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
            <table class="w-full border-collapse text-sm">
                <thead>
                    <tr class="bg-slate-100 text-left">
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Title</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Event Date</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Created</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Last Modified</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Full Tickets</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Concession Tickets</th>
                        <th class="px-4 py-3 font-semibold text-xs uppercase tracking-wider text-slate-500 border-b border-slate-200 whitespace-nowrap">Actions</th>
                    </tr>
                </thead>
                <tbody>
                <% draftEvents.forEach(event => { %>
                    <tr class="hover:bg-slate-50">
                        <td class="px-4 py-3 border-b border-slate-200"><strong><%= event.title %></strong></td>
                        <td class="px-4 py-3 border-b border-slate-200"><%= formatDate(event.event_date, 'd MMM yyyy') %></td>
                        <td class="px-4 py-3 border-b border-slate-200 text-xs text-slate-500 whitespace-nowrap"><%= formatDate(event.created_at, 'dd/MM/yyyy') %></td>
                        <td class="px-4 py-3 border-b border-slate-200 text-xs text-slate-500 whitespace-nowrap"><%= formatDate(event.last_modified, 'dd/MM/yyyy') %></td>
                        <td class="px-4 py-3 border-b border-slate-200">
                            <%= event.full_price_tickets %> available
                            <small class="text-xs text-slate-500">(£<%= parseFloat(event.full_price_cost).toFixed(2) %>)</small>
                        </td>
                        <td class="px-4 py-3 border-b border-slate-200">
                            <%= event.concession_tickets %> available
                            <small class="text-xs text-slate-500">(£<%= parseFloat(event.concession_cost).toFixed(2) %>)</small>
                        </td>
                        <td class="px-4 py-3 border-b border-slate-200">
                            <div class="flex gap-1.5 flex-wrap items-center">
                                <a href="/organiser/events/<%= event.id %>/edit" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold cursor-pointer no-underline whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-transparent text-indigo-600 border-2 border-indigo-600 hover:bg-indigo-50">✏️ Edit</a>
                                <form action="/organiser/events/<%= event.id %>/publish" method="POST" style="display:inline;">
                                    <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold border-none cursor-pointer whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-green-500 text-white hover:bg-green-700">📢 Publish</button>
                                </form>
                                <form action="/organiser/events/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Delete this draft event?');" style="display:inline;">
                                    <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-semibold border-none cursor-pointer whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-red-500 text-white hover:bg-red-700">🗑 Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
