<%- include('../partials/header') %>

<!-- Page header -->
<div class="flex flex-wrap items-start justify-between gap-4 mb-8 pb-6 border-b border-slate-200">
    <div>
        <h1 class="text-3xl font-extrabold text-slate-800">Organiser Home Page</h1>
        <p class="text-slate-500 mt-1"><strong><%= settings.name %></strong> – <%= settings.description %></p>
    </div>
    <div class="flex flex-wrap gap-3">
        <a href="/organiser/settings" class="inline-flex items-center gap-1 border border-indigo-600 text-indigo-600 font-semibold text-sm px-4 py-2 rounded-lg hover:bg-indigo-50 transition">⚙️ Site Settings</a>
        <form action="/organiser/events/new" method="POST">
            <button type="submit" class="inline-flex items-center gap-1 bg-indigo-600 text-white font-semibold text-sm px-4 py-2 rounded-lg hover:bg-indigo-700 transition cursor-pointer">+ Create New Event</button>
        </form>
    </div>
</div>

<!-- Published Events -->
<section class="mb-10">
    <h2 class="text-xl font-bold text-slate-700 mb-4 flex items-center gap-2">
        📢 Published Events
        <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-0.5 rounded-full"><%= publishedEvents.length %></span>
    </h2>

    <% if (publishedEvents.length === 0) { %>
        <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center text-slate-400">
            No published events yet. Publish a draft to make it visible to attendees.
        </div>
    <% } else { %>
        <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm bg-white">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 text-slate-500 uppercase text-xs tracking-wide">
                    <tr>
                        <th class="text-left px-4 py-3">Title</th>
                        <th class="text-left px-4 py-3">Event Date</th>
                        <th class="text-left px-4 py-3">Created</th>
                        <th class="text-left px-4 py-3">Published</th>
                        <th class="text-left px-4 py-3">Full Tickets</th>
                        <th class="text-left px-4 py-3">Concession Tickets</th>
                        <th class="text-left px-4 py-3">Sharing Link</th>
                        <th class="text-left px-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                <% publishedEvents.forEach(function(event) { %>
                    <tr class="hover:bg-slate-50 transition">
                        <td class="px-4 py-3 font-semibold text-slate-800"><%= event.title %></td>
                        <td class="px-4 py-3 text-slate-600 whitespace-nowrap">
                            <%= event.event_date ? new Date(event.event_date).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '—' %>
                        </td>
                        <td class="px-4 py-3 text-slate-400 text-xs whitespace-nowrap"><%= new Date(event.created_at).toLocaleDateString('en-GB') %></td>
                        <td class="px-4 py-3 text-slate-400 text-xs whitespace-nowrap"><%= event.published_at ? new Date(event.published_at).toLocaleDateString('en-GB') : '—' %></td>
                        <td class="px-4 py-3 text-slate-600">
                            <span class="block"><%= event.booked_full %> / <%= event.full_price_tickets %> booked</span>
                            <span class="text-xs text-slate-400">£<%= parseFloat(event.full_price_cost).toFixed(2) %> each</span>
                        </td>
                        <td class="px-4 py-3 text-slate-600">
                            <span class="block"><%= event.booked_concession %> / <%= event.concession_tickets %> booked</span>
                            <span class="text-xs text-slate-400">£<%= parseFloat(event.concession_cost).toFixed(2) %> each</span>
                        </td>
                        <td class="px-4 py-3">
                            <a href="/attendee/events/<%= event.id %>" class="text-indigo-500 text-xs hover:underline whitespace-nowrap">🔗 /attendee/events/<%= event.id %></a>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex gap-2 flex-wrap">
                                <a href="/organiser/events/<%= event.id %>/bookings" class="text-xs border border-slate-300 text-slate-600 px-3 py-1 rounded-lg hover:bg-slate-100 transition">📋 Bookings</a>
                                <form action="/organiser/events/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Delete this event and all its bookings?')">
                                    <button type="submit" class="text-xs bg-red-500 text-white px-3 py-1 rounded-lg hover:bg-red-600 transition cursor-pointer">🗑 Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<!-- Draft Events -->
<section>
    <h2 class="text-xl font-bold text-slate-700 mb-4 flex items-center gap-2">
        📝 Draft Events
        <span class="bg-orange-100 text-orange-700 text-xs font-bold px-2 py-0.5 rounded-full"><%= draftEvents.length %></span>
    </h2>

    <% if (draftEvents.length === 0) { %>
        <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center text-slate-400">
            No draft events. Click <strong>+ Create New Event</strong> to get started.
        </div>
    <% } else { %>
        <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm bg-white">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 text-slate-500 uppercase text-xs tracking-wide">
                    <tr>
                        <th class="text-left px-4 py-3">Title</th>
                        <th class="text-left px-4 py-3">Event Date</th>
                        <th class="text-left px-4 py-3">Created</th>
                        <th class="text-left px-4 py-3">Last Modified</th>
                        <th class="text-left px-4 py-3">Full Tickets</th>
                        <th class="text-left px-4 py-3">Concession Tickets</th>
                        <th class="text-left px-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                <% draftEvents.forEach(function(event) { %>
                    <tr class="hover:bg-slate-50 transition">
                        <td class="px-4 py-3 font-semibold text-slate-800"><%= event.title %></td>
                        <td class="px-4 py-3 text-slate-600 whitespace-nowrap">
                            <%= event.event_date ? new Date(event.event_date).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) : '—' %>
                        </td>
                        <td class="px-4 py-3 text-slate-400 text-xs whitespace-nowrap"><%= new Date(event.created_at).toLocaleDateString('en-GB') %></td>
                        <td class="px-4 py-3 text-slate-400 text-xs whitespace-nowrap"><%= new Date(event.last_modified).toLocaleDateString('en-GB') %></td>
                        <td class="px-4 py-3 text-slate-600">
                            <%= event.full_price_tickets %> available
                            <span class="text-xs text-slate-400 block">£<%= parseFloat(event.full_price_cost).toFixed(2) %> each</span>
                        </td>
                        <td class="px-4 py-3 text-slate-600">
                            <%= event.concession_tickets %> available
                            <span class="text-xs text-slate-400 block">£<%= parseFloat(event.concession_cost).toFixed(2) %> each</span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex gap-2 flex-wrap">
                                <a href="/organiser/events/<%= event.id %>/edit" class="text-xs border border-indigo-400 text-indigo-600 px-3 py-1 rounded-lg hover:bg-indigo-50 transition">✏️ Edit</a>
                                <form action="/organiser/events/<%= event.id %>/publish" method="POST" style="display:inline">
                                    <button type="submit" class="text-xs bg-green-500 text-white px-3 py-1 rounded-lg hover:bg-green-600 transition cursor-pointer">📢 Publish</button>
                                </form>
                                <form action="/organiser/events/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Delete this draft?')" style="display:inline">
                                    <button type="submit" class="text-xs bg-red-500 text-white px-3 py-1 rounded-lg hover:bg-red-600 transition cursor-pointer">🗑 Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<%- include('../partials/footer') %>
