<%- include('../partials/header') %>

<div class="flex items-start justify-between gap-4 mb-8 pb-6 border-b border-slate-200">
    <h1 class="text-3xl font-extrabold text-slate-800">Site Settings</h1>
    <a href="/organiser" class="inline-flex items-center gap-1 border border-slate-300 text-slate-600 font-semibold text-sm px-4 py-2 rounded-lg hover:bg-slate-100 transition">← Back to Organiser Home</a>
</div>

<div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-8 max-w-2xl">

    <% if (errors.length > 0) { %>
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-xl p-4 mb-6">
            <ul class="list-disc list-inside space-y-1 text-sm">
                <% errors.forEach(function(err) { %><li><%= err %></li><% }); %>
            </ul>
        </div>
    <% } %>

    <form action="/organiser/settings" method="POST">

        <div class="mb-5">
            <label for="name" class="block text-sm font-semibold text-slate-700 mb-1">
                Site / Organisation Name <span class="text-red-500">*</span>
            </label>
            <input type="text" id="name" name="name"
                   value="<%= settings.name %>"
                   placeholder="e.g. Stretch Yoga"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" />
            <p class="text-xs text-slate-400 mt-1">This name is shown to attendees on the public site.</p>
        </div>

        <div class="mb-6">
            <label for="description" class="block text-sm font-semibold text-slate-700 mb-1">
                Site Description <span class="text-red-500">*</span>
            </label>
            <textarea id="description" name="description" rows="4"
                      placeholder="e.g. Yoga classes for all ages and abilities"
                      class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 transition resize-y"><%= settings.description %></textarea>
            <p class="text-xs text-slate-400 mt-1">A short description of what your organisation does.</p>
        </div>

        <div class="flex gap-3 pt-4 border-t border-slate-100">
            <button type="submit" class="bg-indigo-600 text-white font-semibold text-sm px-5 py-2 rounded-lg hover:bg-indigo-700 transition cursor-pointer">💾 Save Settings</button>
            <a href="/organiser" class="border border-slate-300 text-slate-600 font-semibold text-sm px-5 py-2 rounded-lg hover:bg-slate-100 transition">Cancel</a>
        </div>

    </form>
</div>

<%- include('../partials/footer') %>
