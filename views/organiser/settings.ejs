<%- include('../partials/header') %>

<div class="flex items-start justify-between flex-wrap gap-4 mb-8 pb-5 border-b-2 border-slate-200">
    <h1 class="text-2xl font-bold">Site Settings</h1>
    <a href="/organiser" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer no-underline whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-transparent text-indigo-600 border-2 border-indigo-600 hover:bg-indigo-50">← Back to Organiser Home</a>
</div>

<div class="bg-white border border-slate-200 rounded-lg p-8 max-w-[680px] shadow-sm mb-8">
    <% if (errors.length > 0) { %>
        <div class="bg-red-50 border border-red-300 text-red-900 rounded-lg px-5 py-3 mb-5 text-sm">
            <ul class="pl-5 list-disc">
                <% errors.forEach(err => { %>
                    <li class="mt-1"><%= err %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <form action="/organiser/settings" method="POST" novalidate>
        <div class="mb-5">
            <label for="name" class="block text-sm font-semibold mb-1">Site / Organisation Name <span class="text-red-500">*</span></label>
            <input
                type="text"
                id="name"
                name="name"
                class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all"
                value="<%= settings.name %>"
                placeholder="e.g. Stretch Yoga"
                required
            />
            <small class="text-xs text-slate-500 mt-1 block">This is the name shown to attendees on the public site.</small>
        </div>

        <div class="mb-5">
            <label for="description" class="block text-sm font-semibold mb-1">Site Description <span class="text-red-500">*</span></label>
            <textarea
                id="description"
                name="description"
                class="w-full px-3.5 py-2.5 border-2 border-slate-200 rounded-lg text-sm bg-white text-slate-800 focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/10 transition-all resize-y"
                rows="4"
                placeholder="e.g. Yoga classes for all ages and abilities"
                required
            ><%= settings.description %></textarea>
            <small class="text-xs text-slate-500 mt-1 block">A short description of what your organisation does.</small>
        </div>

        <div class="flex gap-3 pt-4 mt-2 border-t border-slate-200 flex-wrap">
            <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold border-none cursor-pointer whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md active:translate-y-0 bg-indigo-600 text-white hover:bg-indigo-800">💾 Save Settings</button>
            <a href="/organiser" class="inline-flex items-center gap-1.5 px-5 py-2 rounded-lg text-sm font-semibold cursor-pointer no-underline whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md bg-transparent text-indigo-600 border-2 border-indigo-600 hover:bg-indigo-50">Cancel</a>
        </div>
    </form>
</div>

<%- include('../partials/footer') %>
