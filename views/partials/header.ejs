<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Event Manager</title>
    <!-- Tailwind CSS via CDN (no build step required) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: { DEFAULT: '#4f46e5', dark: '#3730a3', light: '#eef2ff' }
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="/main.css" />
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col font-sans">

<!-- Navbar -->
<nav class="bg-white border-b border-slate-200 shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-indigo-600 font-bold text-lg tracking-tight hover:text-indigo-800 transition">🎟 Event Manager</a>
        <div class="flex gap-6">
            <a href="/organiser" class="text-slate-500 text-sm font-medium hover:text-indigo-600 transition">Organiser</a>
            <a href="/attendee"  class="text-slate-500 text-sm font-medium hover:text-indigo-600 transition">Attendee</a>
        </div>
    </div>
</nav>

<main class="max-w-6xl mx-auto w-full px-4 py-8 flex-1">
